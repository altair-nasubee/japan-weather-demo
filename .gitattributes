# テキストファイルの改行を自動正規化
* text=auto

# C# スクリプト
*.cs text eol=lf diff=csharp

# Unity YAML（シーン・プレハブ・マテリアル等）— テキストとして扱う
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.mask text eol=lf
*.physicsMaterial2D text eol=lf
*.physicMaterial text eol=lf
*.flare text eol=lf
*.fontsettings text eol=lf
*.giparams text eol=lf
*.guiskin text eol=lf
*.inputactions text eol=lf
*.meta text eol=lf

# シェーダー
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.glsl text eol=lf
*.compute text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf

# ---- LFS: バイナリアセット ----

# テクスチャ
